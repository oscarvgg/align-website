{{- $pages := where .Site.AllPages "Kind" "in" (slice "page" "section") -}}
{{- $pages = where $pages "RelPermalink" "ne" "/404/" -}}
{{- $pages = where $pages "RelPermalink" "ne" "/404.html" -}}
{{- $pages = sort $pages "RelPermalink" -}}
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
  {{- range $pages }}
  {{- $changefreq := "monthly" -}}
  {{- $priority := "0.5" -}}
  {{- if and (eq .Kind "section") (eq .Section "blog") -}}
    {{- $changefreq = "daily" -}}
    {{- $priority = "1.0" -}}
  {{- end }}
  {{- $lastmod := .Lastmod -}}
  {{- if lt $lastmod.Unix 1 -}}
    {{- $lastmod = now -}}
  {{- end }}
  <url>
    <loc>{{ .Permalink }}</loc>
    <changefreq>{{ $changefreq }}</changefreq>
    <priority>{{ $priority }}</priority>
    <lastmod>{{ $lastmod.Format "2006-01-02" }}</lastmod>
  </url>
  {{- end }}
</urlset>
