{{- $base := strings.TrimSuffix "/" .Site.BaseURL -}}
{{- $posts := (where .Site.RegularPages "Section" "blog").ByDate.Reverse -}}
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ .Site.Title }}</title>
    <description>{{ .Site.Params.description }}</description>
    <link>{{ $base }}</link>
    <language>{{ .Site.Language.Lang | default "en" }}</language>
    <lastBuildDate>{{ now.Format "Mon, 2 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <pubDate>{{ now.Format "Mon, 2 Jan 2006 15:04:05 -0700" }}</pubDate>
    <ttl>250</ttl>
    <atom:link href="{{ $base }}/feed.rss" rel="self" type="application/rss+xml"/>
    {{- range $posts }}
    {{- $link := strings.TrimSuffix "/" .Permalink -}}
    <item>
      <guid isPermaLink="true">{{ $link }}</guid>
      <title>{{ .Title }}</title>
      <description>{{ .Description | default .Params.description }}</description>
      <link>{{ $link }}</link>
      <pubDate>{{ .Date.Format "Mon, 2 Jan 2006 15:04:05 -0700" }}</pubDate>
      <content:encoded><![CDATA[{{ partial "sanitize-content.html" .Content }}]]></content:encoded>
    </item>
    {{- end }}
  </channel>
</rss>
